{
    "mcpServers": {
        "shift": {
            "command": "php",
            "args": [
                "artisan",
                "mcp:start",
                "shift"
            ]
        },
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        }
    }
}
