APP_NAME=SHIFT
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# AI features use Laravel AI and may share this default provider.
AI_DEFAULT_PROVIDER=openai
AI_REWRITE_ENABLED=false
# AI_REWRITE_PROVIDER=openai
# AI_REWRITE_MODEL=
AI_REWRITE_TIMEOUT=60
AI_EMAIL_IMPORT_ENABLED=false
# AI_EMAIL_IMPORT_PROVIDER=openai
# AI_EMAIL_IMPORT_MODEL=
AI_EMAIL_IMPORT_TIMEOUT=60

# OpenAI (used by both features when selected above).
OPENAI_API_KEY=
OPENAI_STORE=false

# Optional local providers.
OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_API_KEY=
LMSTUDIO_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=local-model
# LMSTUDIO_API_KEY=

SHIFT_MCP_WEB_ENABLED=false
# Use a dedicated Sanctum token created with the exact "mcp:use" ability.
# SHIFT_MCP_AUTH_TOKEN=
# Optional local stdio fallback when no bearer token is present.
# SHIFT_MCP_USER_EMAIL=
# Optional project-token restriction, for example a consuming app's SHIFT_PROJECT value.
# SHIFT_MCP_PROJECT_TOKEN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=shift
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
